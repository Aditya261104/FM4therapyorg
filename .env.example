# Copy this file to .env.local and fill in your real values.

# Razorpay (LIVE)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxx

# Pricing — change PRICE_INR once and everything updates
PRICE_INR=97
ORIGINAL_PRICE_INR=499
NEXT_PUBLIC_PRICE_INR=97
NEXT_PUBLIC_ORIGINAL_PRICE_INR=499

# Pabbly Connect
PABBLY_WEBHOOK_URL=https://connect.pabbly.com/workflow/sendwebhookdata/xxxxxxxx

# Meta Conversions API (optional, both required if used)
META_PIXEL_ID=1234567890123456
META_CAPI_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Meta Pixel (client-side base script + PageView). Same numeric ID as META_PIXEL_ID.
NEXT_PUBLIC_META_PIXEL_ID=1234567890123456

# Analytics (public, written into script tags)
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=xxxxxxxxxx

# Test/QA coupon (server-only). When applied on checkout, total becomes ₹0,
# Razorpay is bypassed, Pabbly webhook still fires with is_test=yes so you can
# verify the redirect to /thank-you end-to-end. Leave blank to disable.
CHECKOUT_COUPON_CODE=tgotest2025

# WhatsApp community
NEXT_PUBLIC_WHATSAPP_URL=https://chat.whatsapp.com/your-invite-code
